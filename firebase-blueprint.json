{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user account with balance and transaction history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "balance": { "type": "number", "description": "Current wallet balance" },
        "totalDeposits": { "type": "number" },
        "totalWithdrawals": { "type": "number" },
        "isAdmin": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "balance", "isAdmin"]
    },
    "Deposit": {
      "title": "Deposit",
      "description": "User deposit request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "method": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "User withdrawal request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "walletAddress": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status", "walletAddress"]
    },
    "Investment": {
      "title": "Investment",
      "description": "User investment plan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "planName": { "type": "string" },
        "amount": { "type": "number" },
        "currentProfit": { "type": "number" },
        "totalProfit": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "planName", "amount", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification for users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "'all' or specific user ID" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "alert"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/deposits/{depositId}": {
      "schema": "Deposit",
      "description": "Deposit transactions"
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "Withdrawal",
      "description": "Withdrawal transactions"
    },
    "/investments/{investmentId}": {
      "schema": "Investment",
      "description": "Active and past investments"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Global and targeted notifications"
    }
  }
}
